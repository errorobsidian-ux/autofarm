local farmTask = nil
local slowFarmTask = nil

AutoTab:CreateToggle({Name = "Auto Garden (Insta-Grow)", CurrentValue = false, Flag = "Toggle1", Callback = function(v) 
    State.farm = v
    print("Auto Garden toggle:", v, "Selected seed:", State.selectedSeed)
    if v then
        TeleportToStartCoords()
        
        farmTask = task.spawn(function()
            while State.farm do
                if Network then
                    for i = 1, 10 do
                        if State.farm then
                            pcall(function() 
                                if Network:FindFirstChild("Instancing_InvokeCustomFromClient") then
                                    print("Planting seed", i, State.selectedSeed)
                                    Network.Instancing_InvokeCustomFromClient:InvokeServer("FlowerGarden", "PlantSeed", i, State.selectedSeed) 
                                    task.wait(0.1)
                                    print("Insta-growing seed", i)
                                    Network.Instancing_InvokeCustomFromClient:InvokeServer("FlowerGarden", "InstaGrowSeed", i) 
                                end
                                if Network:FindFirstChild("Instancing_FireCustomFromClient") then
                                    task.wait(0.1)
                                    print("Claiming plant", i)
                                    Network.Instancing_FireCustomFromClient:FireServer("FlowerGarden", "ClaimPlant", i) 
                                end
                            end)
                            task.wait(0.2)
                        end
                        if not State.farm then break end
                    end
                end
                task.wait(State.fD)
            end
            farmTask = nil
        end)
    else
        State.farm = false
    end
end})

AutoTab:CreateToggle({Name = "Slow Auto Farm + Auto Collect", CurrentValue = false, Flag = "Toggle5", Callback = function(v) 
    State.slowFarm = v
    if v then
        TeleportToStartCoords()
        StartSharedTpRotation()
        
        slowFarmTask = task.spawn(function()
            while State.slowFarm do
                if Network and Network:FindFirstChild("Instancing_InvokeCustomFromClient") then
                    for i = 1, 10 do
                        pcall(function() 
                            Network.Instancing_InvokeCustomFromClient:InvokeServer("FlowerGarden", "PlantSeed", i, State.selectedSeed) 
