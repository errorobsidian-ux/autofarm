local RunService = game:GetService("RunService")

-- Wait for Network with error handling
local Network = ReplicatedStorage:FindFirstChild("Network")
if not Network then
    warn("Network not found in ReplicatedStorage")
    for _, child in pairs(ReplicatedStorage:GetDescendants()) do
        if child.Name == "Network" then
            Network = child
            break
        end
    end
end

--// State
local State = {
    farm = false, slowFarm = false, gift = false, buyMaster = false,
    fD = 0.5, gD = 0.5, selectedSeed = "Diamond",
    slots = {false, false, false, false, false, false}
}

local BlacklistedIDs = {4411364140, 8737899170}

--// Helper Functions
local function IsDangerInServer()
    for _, player in ipairs(Players:GetPlayers()) do
        if table.find(BlacklistedIDs, player.UserId) then return true end
    end
    return false
end

local function TeleportToStartCoords()
    pcall(function()
        local character = Players.LocalPlayer.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.CFrame = CFrame.new(-451, 111, -1400)
        end
    end)
end

local tpRotationTask = nil
local function StartSharedTpRotation()
    if tpRotationTask then return end 
    
    tpRotationTask = task.spawn(function()
        while State.farm or State.slowFarm do
            for i = 1, 600 do
                if not (State.farm or State.slowFarm) then break end
                task.wait(1)
            end
            if not (State.farm or State.slowFarm) then break end
            
            pcall(function()
                local character = Players.LocalPlayer.Character
                local hrp = character and character:FindFirstChild("HumanoidRootPart")
                
                if hrp then
                    local targetCoordinates = {
                        CFrame.new(-436, 111, -1400),
                        CFrame.new(-453, 111, -1375),
                        CFrame.new(-455, 111, -1423),
                        CFrame.new(-451, 111, -1400) 
                    }
                    
                    for _, targetCFrame in ipairs(targetCoordinates) do
                        if not (State.farm or State.slowFarm) then break end
                        hrp.CFrame = targetCFrame
                        task.wait(1)
                    end
                end
            end)
        end
        tpRotationTask = nil
    end)
end

