                    if not State.slowFarm then break end
                    task.wait(1)
                end
                if not State.slowFarm then break end
                
                if Network and Network:FindFirstChild("Instancing_FireCustomFromClient") then
                    for i = 1, 10 do
                        pcall(function() 
                            Network.Instancing_FireCustomFromClient:FireServer("FlowerGarden", "ClaimPlant", i) 
                        end)
                        task.wait(0.3)
                    end
                end
            end
            slowFarmTask = nil
        end)
    else
        State.slowFarm = false
    end
end})

