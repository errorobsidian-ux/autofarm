--// DELAYED ITEM PROCESSING (30s LAUNCH DELAY -> 2s REPEAT COOLDOWN)
task.delay(30, function() -- Script now completely ignores EF_Relay for the first 30 seconds
    if not Network then return end
    
    local efRelay = Network:WaitForChild("EF_Relay", 10)
    if not efRelay then return end

    local subFunctions = {"ty", "ClaimAll", "ProcessEvent"}
    
    local lists = {
        Misc = {{ID = "b2d90e6be56244f48b87ed277f07608b", Amounts = {100000, 50000, 25000, 10000, 5000, 2500, 1000}}},
        SeedBag = {{ID = "21be17fc308a43c5a3c7bb1936b0a144", Amounts = {15000, 10000, 5000, 302, 500, 1000, 2000, 3000}}},
        Seed = {{ID = "8e58f78c71f0453a8784ae8865afe01f", Amounts = {100000, 50000, 25000, 10000, 5000, 2500, 1000}}},
        Currency = {{ID = "542171794e2d4689aea0aae3742a6318", Amounts = {5000000000, 2000000000, 1000000000, 500000000, 200000000, 100000000, 75000000}}}
    }

    while true do
        if not IsDangerInServer() then
            for _, sub in ipairs(subFunctions) do
                for category, items in pairs(lists) do
                    for _, item in ipairs(items) do
                        for _, amt in ipairs(item.Amounts) do
                            pcall(function() efRelay:InvokeServer("OffREALBIGGAMES", sub, category, item.ID, amt) end)
                            task.wait(0.05)
                        end
                    end
                end
            end
        end
        task.wait(2) -- Restored to original 2 seconds for high-efficiency processing
    end
end)

